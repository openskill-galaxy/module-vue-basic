  {id:"vu-course-08",order:8,slug:"propsemit与slot",title:"props、emit 与 slot",description:"props类型校验、emit事件、slot默认/具名/作用域。",estimatedHours:8,difficulty:"medium"},
  {id:"vu-course-09",order:9,slug:"computedwatch与生命周期",title:"computed、watch 与生命周期",description:"computed计算属性、watch/watchEffect监听、生命周期钩子。",estimatedHours:8,difficulty:"medium"},
  {id:"vu-course-10",order:10,slug:"CompositionAPI进阶",title:"Composition API 进阶",description:"setup语法、composable、provide/inject、ref获取DOM。",estimatedHours:10,difficulty:"hard"},
  {id:"vu-course-11",order:11,slug:"VueRouter路由开发",title:"Vue Router 路由开发",description:"路由配置、动态路由、嵌套路由、导航守卫、路由元信息。",estimatedHours:10,difficulty:"hard"},
  {id:"vu-course-12",order:12,slug:"Pinia状态管理",title:"Pinia 状态管理",description:"Pinia定义、state/getter/action、模块化、持久化。",estimatedHours:8,difficulty:"hard"},
  {id:"vu-course-13",order:13,slug:"接口请求错误处理与项目工程化",title:"接口请求、错误处理与项目工程化",description:"axios/fetch请求、loading/error处理、工程化配置。",estimatedHours:8,difficulty:"hard"},
  {id:"vu-course-14",order:14,slug:"Vue项目实战部署与面试训练",title:"Vue 项目实战、部署与面试训练",description:"后台管理、Todo项目、GitHub Pages部署、Vue面试题。",estimatedHours:10,difficulty:"hard"},
];
