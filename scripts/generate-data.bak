  {id:"vu-course-04",order:4,slug:"响应式基础ref与reactive",title:"响应式基础：ref 与 reactive",description:"ref、reactive、响应式原理、toRef/toRefs。",estimatedHours:8,difficulty:"medium"},
  {id:"vu-course-05",order:5,slug:"事件处理与表单绑定",title:"事件处理与表单绑定",description:"事件监听、事件修饰符、v-model表单绑定、修饰符。",estimatedHours:6,difficulty:"easy"},
