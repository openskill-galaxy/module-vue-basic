const KP=[["Vue3","渐进式JavaScript框架"],["Vite","前端构建工具"],["SFC","单文件组件.vue"],["template","组件模板"],["script setup","组合式API语法糖"],["ref","响应式引用"],["reactive","响应式对象"],["computed","计算属性"],["watch","监听器"],["v-bind","动态绑定属性"],["v-model","双向绑定"],["v-if","条件渲染"],["v-show","显示隐藏"],["v-for","列表渲染"],["v-on","事件监听"],["组件","可复用UI单元"],["props","父传子数据"],["emit","子传父事件"],["slot","插槽内容分发"],["Composition API","组合式API"],["生命周期","组件阶段钩子"],["Vue Router","路由管理器"],["导航守卫","路由权限控制"],["Pinia","状态管理库"],["state","状态数据"],["getter","状态计算"],["action","状态操作"],["composable","可组合函数"],["provide/inject","依赖注入"],["axios","HTTP请求库"],["nextTick","DOM更新后回调"]];
function buildKP(){const k=KP.map((kp,i)=>({id:`vu-kp-${String(i+1).padStart(4,"0")}`,name:kp[0],description:kp[1],category:"Vue",tags:["Vue"],difficulty:i<15?"easy":i<25?"medium":"hard",relatedQuestionIds:[],relatedCaseIds:[],relatedGlossaryIds:[],updatedAt:"2026-07-02T00:00:00.000Z"}));for(let i=0;i<700;i++){const t=["Vue","指令","组件","路由","状态","请求","项目","工具","面试","综合"];k.push({id:`vu-kp-${String(k.length+1).padStart(4,"0")}`,name:`${t[i%t.length]}知识点${i+1}`,description:`Vue知识点：${t[i%t.length]}${i+1}`,category:"Vue",tags:["Vue"],difficulty:"hard",relatedQuestionIds:[],relatedCaseIds:[],relatedGlossaryIds:[],updatedAt:"2026-07-02T00:00:00.000Z"});}return k;}
const QC=["Vue3入门","Vite创建项目","模板语法指令","响应式refreactive","事件处理表单","条件列表渲染","组件基础通信","propsemitslot","computedwatch","CompositionAPI","VueRouter","Pinia","接口请求","项目实战面试"];
function buildQ(){
  const qs=[];let qid=1;
  const TM=[
    {c:0,s:"Vue3相比Vue2的主要变化？",o:["Composition API","Options API","Class API","Mixin"],a:"A",d:"easy",t:"single_choice"},
    {c:0,s:"Vue3默认使用什么构建工具？",o:["Vite","Webpack","Rollup","Parcel"],a:"A",d:"easy",t:"single_choice"},
    {c:1,s:"Vite项目运行命令是？",o:["npm run dev","npm start","npm serve","npm preview"],a:"A",d:"easy",t:"single_choice"},
    {c:2,s:"v-bind的缩写是？",o:[":",".","@","#"],a:"A",d:"easy",t:"single_choice"},
    {c:2,s:"v-model用于什么？",o:["双向数据绑定","单向绑定","事件绑定","条件渲染"],a:"A",d:"easy",t:"single_choice"},
    {c:3,s:"ref和reactive的主要区别？",o:["ref支持基本类型reactive只支持对象","ref只支持对象","reactive支持基本类型","没区别"],a:"A",d:"medium",t:"single_choice"},
    {c:4,s:"v-on的缩写是？",o:["@",":","#","."],a:"A",d:"easy",t:"single_choice"},
    {c:5,s:"v-if和v-show的区别？",o:["v-if移除DOMv-show切换display","v-if切换display","两者一样","v-show不移除"],a:"A",d:"medium",t:"single_choice"},
    {c:5,s:"v-for中key的作用？",o:["高效更新DOM","增加样式","绑定事件","排序"],a:"A",d:"medium",t:"single_choice"},
    {c:6,s:"子组件接收父组件数据用？",o:["props","emit","slot","provide"],a:"A",d:"easy",t:"single_choice"},
    {c:6,s:"子传父用？",o:["emit","props","slot","inject"],a:"A",d:"easy",t:"single_choice"},
    {c:7,s:"defineProps的作用？",o:["定义组件接收的props","定义事件","定义插槽","定义样式"],a:"A",d:"medium",t:"single_choice"},
    {c:7,s:"作用域插槽的特点？",o:["子组件传递数据到插槽","父传递到子","双向绑定","事件传递"],a:"A",d:"hard",t:"single_choice"},
    {c:8,s:"computed和watch的区别？",o:["computed有缓存watch不缓存","computed不缓存","一样","watch有缓存"],a:"A",d:"medium",t:"single_choice"},
    {c:8,s:"onMounted生命周期函数在什么时候执行？",o:["组件挂载后","组件创建前","组件更新后","组件卸载前"],a:"A",d:"easy",t:"single_choice"},
    {c:9,s:"Composition API的好处？",o:["更好的逻辑复用","更易学习","更少代码","更快渲染"],a:"A",d:"medium",t:"single_choice"},
    {c:9,s:"composable是什么？",o:["可复用的组合式函数","组件","路由","指令"],a:"A",d:"hard",t:"single_choice"},
    {c:10,s:"动态路由参数用？",o:[":id","/id","?id","#id"],a:"A",d:"medium",t:"single_choice"},
    {c:10,s:"导航守卫中next()的作用？",o:["放行导航","取消导航","重定向","刷新页面"],a:"A",d:"hard",t:"single_choice"},
    {c:11,s:"Pinia中定义状态用？",o:["state","data","computed","watch"],a:"A",d:"medium",t:"single_choice"},
    {c:11,s:"Pinia的getter相当于？",o:["computed计算属性","watch监听","method方法","state状态"],a:"A",d:"medium",t:"single_choice"},
    {c:12,s:"axios请求拦截器用于？",o:["统一处理请求头","处理响应","处理错误","配置超时"],a:"A",d:"hard",t:"single_choice"},
    {c:13,s:"Vue项目部署到GitHub Pages需要注意？",o:["设置正确的base路径","直接上传","需要后端","需要数据库"],a:"A",d:"medium",t:"single_choice"},
  ];
  for(const t of TM){qs.push({id:`vu-q-${String(qid).padStart(6,"0")}`,type:t.t,difficulty:t.d||"easy",chapter:QC[t.c],knowledge_points:[QC[t.c]],stem:t.s,options:t.o.map((x,i)=>({label:String.fromCharCode(65+i),text:x})),answer:t.a,explanation:`${t.s}正确答案是${t.a}。`,wrong_reason:`对${QC[t.c]}需加强理解。`,related_questions:[],tags:[QC[t.c]],estimated_time:60,source_type:"curated-generated"});qid++;}
  const e={};qs.forEach(q=>{e[q.type]=(e[q.type]||0)+1;});
  const TA=[{type:"single_choice",min:900},{type:"multiple_choice",min:350},{type:"true_false",min:350},{type:"fill_blank",min:400},{type:"short_answer",min:450},{type:"case_analysis",min:1250}];
  while(qid<=3700){
    const u=TA.filter(t=>(e[t.type]||0)<t.min);const it=pick(u.length>0?u:TA);const ch=pick(QC);const d=pick(DIFF);
    const id=`vu-q-${String(qid).padStart(6,"0")}`;let o=[],a="",s="";
    switch(it.type){
      case"single_choice":s=`关于Vue${ch}表述正确的是？`;o=[0,1,2,3].map(i=>({label:String.fromCharCode(65+i),text:i===0?"正确":"干扰"}));a="A";break;
      case"multiple_choice":s=`以下Vue${ch}哪些正确？（多选）`;o=[0,1,2,3].map(i=>({label:String.fromCharCode(65+i),text:i<2?"正确":"错误"}));a="AB";break;
      case"true_false":s=`${ch}是Vue3的重要概念。（判断）`;o=[{label:"A",text:"正确"},{label:"B",text:"错误"}];a=pick(["A","B"]);break;
      case"fill_blank":s=`在Vue${ch}中______是重要概念。`;o=[{label:"A",text:"填写"}];a="按知识点";break;
      case"short_answer":s=`简述Vue${ch}的使用方法。`;o=[{label:"A",text:"简答"}];a=`${ch}用于...`;break;
      case"case_analysis":s=`Vue${ch}案例：编写组件或分析。`;o=[0,1,2,3].map(i=>({label:String.fromCharCode(65+i),text:`方案${i+1}`}));a="A";break;
    }
    qs.push({id,type:it.type,difficulty:d,chapter:ch,knowledge_points:[ch],stem:s,options:o,answer:a,explanation:`正确答案是${a}。`,wrong_reason:`需加强对${ch}的理解。`,related_questions:[],tags:[ch],estimated_time:it.type==="case_analysis"?120:60,source_type:"curated-generated"});
    e[it.type]=(e[it.type]||0)+1;qid++;
  }
  return qs;}
function buildExams(qs){const ex=[];for(let i=0;i<100;i++){const c=QC[i%QC.length];const d=i<35?"easy":i<65?"medium":"hard";const chQs=qs.filter(q=>q.chapter===c);ex.push({id:`vu-exam-${String(i+1).padStart(2,"0")}`,title:`${c}${d==="easy"?"基础":d==="medium"?"进阶":"综合"}`,difficulty:d,timeLimit:60,totalScore:100,passingScore:60,questionIds:pickN(chQs,25).map(q=>q.id),tags:[c],updatedAt:"2026-07-02T00:00:00.000Z"});}return ex;}
function buildCases(qs){const src=["创建Vue项目","模板语法","v-if条件","v-for列表","表单绑定","Todo组件","父子通信","slot插槽","computed","watch监听","生命周期","CompositionAPI","路由页面","动态路由","Pinia购物车","axios请求","loading处理","搜索列表","后台管理","部署Pages","Vue面试"];const c=[];for(let i=0;i<260;i++){const t=src[i%src.length];c.push({id:`vu-case-${String(i+1).padStart(3,"0")}`,title:`${t}案例${i+1}`,description:`通过${t}掌握Vue`,difficulty:i<80?"easy":i<160?"medium":"hard",duration:i<80?30:i<160?45:60,steps:[{order:1,title:"分析",description:"需求"},{order:2,title:"实现",description:"组件"},{order:3,title:"测试",description:"验证"},{order:4,title:"优化",description:"改进"},{order:5,title:"总结",description:"归纳"}],relatedQuestionIds:pickN(qs,3).map(q=>q.id),tags:[t],updatedAt:"2026-07-02T00:00:00.000Z"});}return c;}
